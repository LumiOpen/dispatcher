#!/bin/bash
#SBATCH --job-name={{ job_name }}
{% for key, value in slurm.items() -%}
{% if value is sameas true -%}
#SBATCH --{{ key.replace('_', '-') }}
{% elif value is sameas false -%}
{% else -%}
#SBATCH --{{ key.replace('_', '-') }}={{ value }}
{% endif -%}
{% endfor -%}

set -euo pipefail

echo "======================================="
echo "{{ job_name }} (CPU Job - sbatch)"
echo "======================================="
echo "Started: $(date)"
echo ""

cd {{ base_dir }}

# ============================================================
# Python Environment Setup
# ============================================================
{% if cpu_python_modules is defined %}
{% for mod in cpu_python_modules %}
module load {{ mod }}
{% endfor %}
{% endif %}
mkdir -p logs pythonuserbase
export PYTHONUSERBASE="$(pwd)/pythonuserbase"
export PATH="$PYTHONUSERBASE/bin:$PATH"
export PYTHONPATH="$(pwd):${PYTHONPATH:-}"
export HF_HOME="{{ hf_home }}"
mkdir -p "$HF_HOME/hub"

{% if container is defined %}
# Run commands inside container (host env vars are inherited)
_run() { singularity exec -B /shared_silo:/shared_silo {{ container }} "$@"; }
echo "Container: {{ container }}"
echo "Python: $(_run python3 --version 2>&1)"
{% else %}
_run() { "$@"; }
echo "Python: $(python3 --version) ($(which python3))"
{% endif %}

{% if exports is defined %}
# ============================================================
# Set Environment Variables
# ============================================================
{% for key, value in exports.items() %}
export {{ key }}="{{ value }}"
{% endfor %}
{% endif %}

{% if container is defined and pip_extras is defined %}
# ============================================================
# Venv Setup (system-site-packages inherits container packages)
# ============================================================
VENV_DIR="$(pwd)/.venv_{{ job_name }}"
rm -rf "$VENV_DIR"
echo "Creating venv with system-site-packages..."
_run python3 -m venv --system-site-packages "$VENV_DIR"

echo "Installing requirements into venv..."
_run "$VENV_DIR/bin/pip" install -r requirements.txt
{% for pkg in pip_extras %}
echo "  {{ pkg }}"
_run "$VENV_DIR/bin/pip" install {{ pkg }}
{% endfor %}
echo "Venv ready: $VENV_DIR"

_run_py() { _run "$VENV_DIR/bin/python3" "$@"; }
{% else %}
# ============================================================
# Install requirements
# ============================================================
echo "Installing requirements..."
_run python3 -m pip install --user -r requirements.txt
{% if pip_extras is defined %}
{% for pkg in pip_extras %}
_run python3 -m pip install --user {{ pkg }}
{% endfor %}
{% endif %}
echo "Requirements installed."

_run_py() { _run python3 "$@"; }
{% endif %}
{% if setup_commands is defined %}

# ============================================================
# Setup Commands
# ============================================================
{% for cmd in setup_commands %}
echo "Setup: {{ cmd }}"
{{ cmd }}
{% endfor %}
echo "Setup commands completed."
{% endif %}

# ============================================================
# Execute Python Script
# ============================================================
echo "Running: python {{ script }}"
echo ""

_run_py {{ script }} \
{%- for key, value in args.items() if value is not none %}
{%- if value is sameas true %}
    --{{ key }}{% if not loop.last %} \{% endif %}
{%- elif value is sameas false %}
{%- else %}
    --{{ key }} "{{ value }}"{% if not loop.last %} \{% endif %}
{%- endif %}
{%- endfor %}


exit_code=$?
if [ $exit_code -ne 0 ]; then
    echo "ERROR: Script failed with exit code $exit_code"
    exit $exit_code
fi

echo ""
echo "Completed: $(date)"
