#!/bin/bash
#SBATCH --job-name={{ job_name }}
{% if slurm.account is defined %}#SBATCH --account={{ slurm.account }}
{% endif %}#SBATCH --partition={{ slurm.partition }}
#SBATCH --time={{ slurm.time | default('00:30:00') }}
#SBATCH --nodes={{ slurm.nodes | default(1) }}
#SBATCH --ntasks-per-node={{ slurm.ntasks_per_node | default(1) }}
#SBATCH --cpus-per-task={{ slurm.cpus_per_task | default(8) }}
#SBATCH --mem={{ slurm.mem | default('32G') }}
#SBATCH --gpus=0
#SBATCH --output={{ slurm.output | default('logs/%j.out') }}
#SBATCH --error={{ slurm.error | default('logs/%j.err') }}

set -euo pipefail

echo "======================================="
echo "{{ job_name }} (CPU Job - sbatch)"
echo "======================================="
echo "Started: $(date)"
echo ""

cd {{ base_dir }}

# ============================================================
# Python Environment Setup
# ============================================================
{% if cpu_python_modules is defined %}
{% for mod in cpu_python_modules %}
module load {{ mod }}
{% endfor %}
{% endif %}
mkdir -p logs pythonuserbase
export PYTHONUSERBASE="$(pwd)/pythonuserbase"
export PATH="$PYTHONUSERBASE/bin:$PATH"
export PYTHONPATH="$(pwd):${PYTHONPATH:-}"
export HF_HOME="{{ hf_home }}"
mkdir -p "$HF_HOME/hub"

echo "Python: $(python3 --version) ($(which python3))"

{% if exports is defined %}
# ============================================================
# Set Environment Variables
# ============================================================
{% for key, value in exports.items() %}
export {{ key }}="{{ value }}"
{% endfor %}
{% endif %}

# ============================================================
# Install requirements
# ============================================================
echo "Installing requirements..."
python3 -m pip install --user -r requirements.txt
echo "Requirements installed."

# ============================================================
# Execute Python Script
# ============================================================
echo "Running: python {{ script }}"
echo ""

python3 {{ script }} \
{%- for key, value in args.items() if value is not none %}
{%- if value is sameas true %}
    --{{ key }}{% if not loop.last %} \{% endif %}
{%- elif value is sameas false %}
{%- else %}
    --{{ key }} "{{ value }}"{% if not loop.last %} \{% endif %}
{%- endif %}
{%- endfor %}


exit_code=$?
if [ $exit_code -ne 0 ]; then
    echo "ERROR: Script failed with exit code $exit_code"
    exit $exit_code
fi

echo ""
echo "Completed: $(date)"
