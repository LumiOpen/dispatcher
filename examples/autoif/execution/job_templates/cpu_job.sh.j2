#!/bin/bash
{% if execution_mode == 'sbatch' %}
#SBATCH --job-name={{ job_name }}
{% for key, value in slurm.items() %}
#SBATCH --{{ key.replace('_', '-') }}={{ value }}
{% endfor %}
{% endif %}

set -euo pipefail

echo "================================"
echo "{{ job_name }}{% if execution_mode == 'interactive' %} (Interactive Mode){% endif %}"
echo "================================"
echo "Started: $(date)"
echo ""

# ============================================================
# Environment Setup
# ============================================================
{% include environment_setup %}

# ============================================================
# Set Environment Variables (if needed)
# ============================================================
{% if function_timeout is defined %}export FUNCTION_TIMEOUT="{{ function_timeout }}"{% endif %}
{% if min_functions is defined %}export MIN_FUNCTIONS="{{ min_functions }}"{% endif %}
{% if min_test_cases is defined %}export MIN_TEST_CASES="{{ min_test_cases }}"{% endif %}
{% if function_pass_rate is defined %}export FUNCTION_PASS_RATE="{{ function_pass_rate }}"{% endif %}

# ============================================================
# Execute Python Script
# ============================================================
echo "Running: python {{ script }}"
echo ""

python {{ script }} \
{% for key, value in args.items() %}
{% if value is not none %}
{% if value is sameas true %}
    --{{ key }}{% if not loop.last %} \{% endif %}
{% elif value is not sameas false %}
    --{{ key }} "{{ value }}"{% if not loop.last %} \{% endif %}
{% endif %}
{% endif %}
{% endfor %}

if [ $? -ne 0 ]; then
    echo "ERROR: Script failed"
    exit 1
fi
