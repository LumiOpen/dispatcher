#!/bin/bash
#SBATCH --job-name={{ job_name }}
#SBATCH --partition={{ slurm.partition | default('amd-tw-verification') }}
#SBATCH --time={{ slurm.time | default('00:30:00') }}
#SBATCH --nodes={{ slurm.nodes | default(1) }}
#SBATCH --ntasks-per-node={{ slurm.ntasks_per_node | default(1) }}
#SBATCH --cpus-per-task={{ slurm.cpus_per_task | default(8) }}
#SBATCH --mem={{ slurm.mem | default('32G') }}
#SBATCH --gpus=0
#SBATCH --output={{ slurm.output | default('logs/%j.out') }}
#SBATCH --error={{ slurm.error | default('logs/%j.err') }}

set -euo pipefail

echo "======================================="
echo "{{ job_name }} (TensorWave CPU Job - sbatch)"
echo "======================================="
echo "Started: $(date)"
echo ""

cd /shared_silo/scratch/adamhrin@amd.com/dispatcher_autoif/examples/autoif

# ============================================================
# Environment Setup
# ============================================================
source /shared_silo/scratch/adamhrin@amd.com/dispatcher_autoif/examples/autoif/execution/environments/singularity_launcher.sh

# Reset trap - CPU jobs do not have a server to kill
trap - EXIT

{% if exports is defined %}
# ============================================================
# Set Environment Variables
# ============================================================
{% for key, value in exports.items() %}
export {{ key }}="{{ value }}"
{% endfor %}
{% endif %}

# ============================================================
# Install requirements
# ============================================================
echo "Installing requirements..."
run_sing_python -m pip install --user -r requirements.txt
echo "Requirements installed."

# ============================================================
# Execute Python Script
# ============================================================
echo "Running: python {{ script }}"
echo ""

run_sing_python {{ script }} \
{%- for key, value in args.items() if value is not none %}
{%- if value is sameas true %}
    --{{ key }}{% if not loop.last %} \{% endif %}
{%- elif value is sameas false %}
{%- else %}
    --{{ key }} "{{ value }}"{% if not loop.last %} \{% endif %}
{%- endif %}
{%- endfor %}

exit_code=$?
if [ $exit_code -ne 0 ]; then
    echo "ERROR: Script failed with exit code $exit_code"
    exit $exit_code
fi

echo ""
echo "Completed: $(date)"
