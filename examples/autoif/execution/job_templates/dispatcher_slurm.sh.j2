#!/bin/bash
#SBATCH --job-name={{ job_name }}
{% for key, value in slurm.items() -%}
{% if value is sameas true -%}
#SBATCH --{{ key.replace('_', '-') }}
{% elif value is sameas false -%}
{% else -%}
#SBATCH --{{ key.replace('_', '-') }}={{ value }}
{% endif -%}
{% endfor %}

set -euxo pipefail

echo "======================================="
echo "{{ job_name }} (Dispatcher Job - sbatch)"
echo "======================================="
echo "Started: $(date)"
echo ""

cd {{ base_dir }}

# ============================================================
# Job Configuration
# ============================================================
TASK="{{ task }}"
INPUT_FILE="{{ input_file }}"
OUTPUT_FILE="{{ output_file }}"
MODEL="{{ model }}"
WORKERS="{{ workers | default(4) }}"
BATCH_SIZE="{{ batch_size | default(1) }}"
WORK_TIMEOUT="{{ work_timeout | default(3600) }}"
GPUS_PER_TASK="{{ tensor_parallel | default(4) }}"
MAX_MODEL_LEN="{{ max_model_len | default(32768) }}"
STARTUP_TIMEOUT="{{ startup_timeout | default(1800) }}"
REQUEST_TIMEOUT="{{ request_timeout | default(1800) }}"

echo "Running {{ job_name }}..."
echo "  Model: $MODEL"
echo "  Input: $INPUT_FILE"
echo "  Output: $OUTPUT_FILE"
echo "  Workers: $WORKERS"
echo "  Tensor Parallel: $GPUS_PER_TASK"
echo ""

# ============================================================
# Host Python Setup (for dispatcher server - no GPU needed)
# ============================================================
{% if cpu_python_modules is defined %}
{% for mod in cpu_python_modules %}
module load {{ mod }}
{% endfor %}
{% endif %}
mkdir -p pythonuserbase
export PYTHONUSERBASE="$(pwd)/pythonuserbase"
export PATH="$PYTHONUSERBASE/bin:$PATH"
export PYTHONPATH="$(pwd):${PYTHONPATH:-}"

echo "Host Python: $(python3 --version) ($(which python3))"
echo "Installing dispatcher package (host)..."
python3 -m pip install --user --upgrade {{ dispatcher_package }}
echo "Dispatcher server package installed."

# ============================================================
# Dispatcher Server (runs on host Python, no GPU access)
# ============================================================
export DISPATCHER_SERVER=$(hostname)
export DISPATCHER_PORT=9999

echo "Starting dispatcher server on $DISPATCHER_SERVER:$DISPATCHER_PORT..."
python3 -m dispatcher.server \
    --infile "$INPUT_FILE" \
    --outfile "$OUTPUT_FILE" \
    --work-timeout "$WORK_TIMEOUT" \
    --host 0.0.0.0 \
    --port $DISPATCHER_PORT &
srv_pid=$!

# Wait for server to be ready
echo "Waiting for dispatcher server..."
for i in $(seq 1 120); do
    (echo >/dev/tcp/$DISPATCHER_SERVER/$DISPATCHER_PORT) >/dev/null 2>&1 && break || true
    sleep 1
done
(echo >/dev/tcp/$DISPATCHER_SERVER/$DISPATCHER_PORT) >/dev/null 2>&1 || {
    echo "[ERROR] dispatcher server did not start"
    exit 1
}
echo "Server is up."

# ============================================================
# Container Environment Setup (for GPU workers)
# ============================================================
source {{ environment_setup }}

# Pre-build wheels on the shared filesystem so every srun worker can install
# without rebuilding from source (avoids node-local /tmp issues and parallel
# build race conditions on setup.py).
WHEEL_DIR="$(pwd)/.wheels"
rm -rf "$WHEEL_DIR"
mkdir -p "$WHEEL_DIR"

echo "Building dispatcher wheel..."
run_sing_python -m pip wheel --wheel-dir "$WHEEL_DIR" {{ dispatcher_package }}
echo "Building requirement wheels..."
run_sing_python -m pip wheel --wheel-dir "$WHEEL_DIR" -r requirements.txt
echo "Wheels ready in $WHEEL_DIR"

# ============================================================
# Dispatcher Workers (with vLLM launch)
# ============================================================
srun -l bash -c '
    source {{ environment_setup }}

    echo "Installing packages from pre-built wheels..."
    run_sing_pip_install --no-index --find-links '"'$WHEEL_DIR'"' dispatcher
    run_sing_pip_install --no-index --find-links '"'$WHEEL_DIR'"' -r requirements.txt
    echo "Packages installed."
{% if pip_extras is defined %}

    echo "Installing extra packages..."
{% for pkg in pip_extras %}
    run_sing_pip_install {{ pkg }}
{% endfor %}
    echo "Extra packages installed."
{% endif %}

    run_sing_bash '\''
        set -euxo pipefail
        
        LOCALID=${SLURM_LOCALID:-0}
        
        # GPU allocation: SLURM cgroups partition and renumber GPUs per task,
        # so each task always sees GPUs 0..GPUS_PER_TASK-1 regardless of LOCALID.
        GPU_IDS=""
        for (( i=0; i<'"'$GPUS_PER_TASK'"'; i++ )); do
            if [ -z "$GPU_IDS" ]; then
                GPU_IDS="$i"
            else
                GPU_IDS="${GPU_IDS},$i"
            fi
        done
        export ROCR_VISIBLE_DEVICES="$GPU_IDS"
        export HIP_VISIBLE_DEVICES="$GPU_IDS"
        
        # Ports
        export MASTER_ADDR=${MASTER_ADDR:-127.0.0.1}
        export MASTER_PORT=$(( 7000 + LOCALID ))
        export VLLM_PORT=$(( 8000 + LOCALID * 100 ))
        
{% if exports is defined %}
        # Task-specific environment variables
{% for key, value in exports.items() %}
        export {{ key }}="{{ value }}"
{% endfor %}
{% endif %}
        
        echo "Launching task LOCALID=$LOCALID on GPUs $GPU_IDS (VLLM_PORT=$VLLM_PORT)"
        
        # Run task manager worker (launches vLLM)
        run_python -m dispatcher.taskmanager.cli \
            --dispatcher '"'$DISPATCHER_SERVER'"':'"'$DISPATCHER_PORT'"' \
            --task '"'$TASK'"' \
            --batch-size '"'$BATCH_SIZE'"' \
            --workers '"'$WORKERS'"' \
            --max-model-len '"'$MAX_MODEL_LEN'"' \
            --tensor-parallel '"'$GPUS_PER_TASK'"' \
            --model '"'$MODEL'"' \
            --port $VLLM_PORT \
            --request-timeout '"'$REQUEST_TIMEOUT'"' \
            --startup-timeout '"'$STARTUP_TIMEOUT'"'{% if vllm_extra_args is defined %} \
            --vllm-extra-args "{{ vllm_extra_args }}"{% endif %} 
    '\''
'

echo ""
echo "Completed: $(date)"
