#!/bin/bash
{% if execution_mode == 'sbatch' -%}
#SBATCH --job-name={{ job_name }}
{% for key, value in slurm.items() -%}
#SBATCH --{{ key.replace('_', '-') }}={{ value }}
{% endfor -%}
{% endif %}

set -euo pipefail

echo "================================"
echo "{{ job_name }}{% if execution_mode == 'interactive' %} (Interactive Mode){% endif %}"
echo "================================"
echo "Started: $(date)"
echo ""

# ============================================================
# Environment Setup
# ============================================================
{% include environment_setup %}

{% if exports is defined %}
# ============================================================
# Set Environment Variables
# ============================================================
{% for key, value in exports.items() %}
export {{ key }}="{{ value }}"
{% endfor %}

{% endif %}
# ============================================================
# Execute Python Script
# ============================================================
echo "Running: python {{ script }}"
echo ""

{%- if args %}
python {{ script }} \
{%- for key, value in args.items() if value is not none %}
{%- if value is sameas true %}
    --{{ key }}{% if not loop.last %} \{% endif %}
{%- elif value is sameas false %}
{%- else %}
    --{{ key }} "{{ value }}"{% if not loop.last %} \{% endif %}
{%- endif %}
{%- endfor %}
{%- else %}
python {{ script }}
{%- endif %}

if [ $? -ne 0 ]; then
    echo "ERROR: Script failed"
    exit 1
fi
